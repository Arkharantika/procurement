PORT=3001

# PostgreSQL connection string.
# Port 5433 = Postgres di Docker (docker-compose.yml, image pgvector/pgvector:pg17
# yang sudah membawa extension pgvector). Postgres Windows biasa di 5432 tidak
# punya pgvector — pencarian vektor butuh yang di Docker.
DATABASE_URL=postgres://user:password@localhost:5433/estimacore

# OpenRouter (LLM)
# Model bebas diganti tanpa ubah kode sedikit pun — isi dengan ID model apa pun
# dari https://openrouter.ai/models. OpenRouter memakai antarmuka yang sama untuk
# semua provider, jadi berpindah model cukup mengganti baris di bawah ini.
# Contoh lain: openai/gpt-4o-mini, openai/gpt-5.4, anthropic/claude-sonnet-4-6
OPENROUTER_API_KEY=your_openrouter_key_here
OPENROUTER_MODEL=openai/gpt-5-mini

# Batas panjang jawaban LLM per request. WAJIB ada — kalau tidak dikirim, OpenRouter
# memakai batas maksimum model (puluhan ribu token) dan MENCADANGKAN kredit sebanyak
# itu di muka, sehingga request ditolak 402 walau jawaban aslinya cuma ratusan token.
# Semua output modul ini berupa JSON pendek, jadi 2000 sudah lebih dari cukup.
# Naikkan hanya kalau ada jawaban yang terpotong di tengah.
OPENROUTER_MAX_TOKENS=2000

# Model embedding untuk pencarian vektor (pgvector) — via endpoint embeddings
# OpenRouter, API key yang sama dengan di atas. HARUS model multibahasa (katalog
# bisa berbahasa Indonesia, query bisa Inggris) dan HARUS mendukung param
# dimensions=1024 (seri text-embedding-3), karena kolomnya vector(1024).
# Ganti model = jalankan ulang `npm run embed -- --all` + ukur ulang VECTOR_MIN_SIM
# di searchService.js.
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-large

# SerpAPI (internet product search)
SERPAPI_KEY=your_serpapi_key_here
